#!/usr/bin/env bash
# One-time environment setup: creates venv, installs deps, links integration.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT"

if [ ! -d .venv ]; then
    echo ">> Creating .venv"
    python -m venv .venv
fi

source .venv/bin/activate

echo ">> Upgrading pip"
pip install --upgrade pip wheel setuptools

echo ">> Installing runtime requirements"
pip install -r requirements.txt

echo ">> Installing test/lint requirements"
pip install -r requirements_test.txt

echo ">> Installing pre-commit hooks"
pre-commit install

echo ">> Linking integration into config/custom_components/"
mkdir -p config/custom_components
ln -sfn ../../custom_components/asset_manager config/custom_components/asset_manager

echo ">> Setup complete. Run: source .venv/bin/activate && hass -c config"